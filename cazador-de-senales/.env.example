# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ─── Apify ──────────────────────────────────────────────────────────────────
APIFY_TOKEN=your-apify-api-token

# ─── Claude / Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Resend (email) ─────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=outreach@tudominio.com

# ─── Control de envío ───────────────────────────────────────────────────────
# DRY_RUN=true  → el sistema detecta y redacta, pero NO envía emails
# DRY_RUN=false → envía emails reales (solo cambiar cuando estés listo)
DRY_RUN=true

# AUTOPILOT_SEND=true  → envía automáticamente si score >= 85
# AUTOPILOT_SEND=false → todo queda como borrador para revisión manual (recomendado al inicio)
AUTOPILOT_SEND=false
